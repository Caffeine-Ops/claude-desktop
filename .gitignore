node_modules
out
dist
build/
*.log
.DS_Store

# fusion-code CLI 二进制 (~35M)：由 CI 在构建时下载（版本钉在
# .github/workflows/build.yml 的 FUSION_CODE_VERSION），不是源码，不入库。
apps/desktop/fusion-bin/

# 自带 Node runtime (~50M/平台)：CI 从 nodejs.org 下载对应平台 Node 24
# （版本钉在 build.yml 的 BUNDLED_NODE_VERSION），打进包给 daemon 用，不入库。
apps/desktop/node-runtime/

# 自带 Python 3.12 runtime (~40-50M/平台)：CI 从 astral-sh/python-build-standalone
# 下载（版本钉在 build.yml 的 PYTHON_STANDALONE_TAG/VERSION），打进包给 ppt-master
# skill 的 ensure-python 脚本当 venv base 用，不是源码，不入库。
apps/desktop/python-runtime/

# skill 的运行时产物（本机跑 skill 时生成，非源码）：
# ppt-master/projects/ 是生成的 PPT 工程；__pycache__/ 是 Python 字节码缓存
# （gpt-image-2 移植成 Python 后也会产生，统一按所有 skill 忽略）。
skills/ppt-master/projects/
skills/**/__pycache__/

# prebundle 打包产物 (~160M)：scripts/prebundle-daemon.mjs 生成（每次先 rm 重建），
# 内容全是从 repo 别处复制来的（daemon bundle + apps/web/out + skills/
# design-systems/… 等根目录资源），无唯一副本。electron-builder 打包时用，
# 重新生成用 `bun run prebundle:daemon`。不入库。
apps/desktop/prebundled/

# 语义检索 ONNX 模型 (~24M)：scripts/prebundle-kb-model.mjs 从 HuggingFace 下载
# （sha256 钉在脚本里），不是源码，不入库。electron-builder extraResources 把
# kb-model/ 整体打进 Resources/kb-model/。重新拉取用 `bun run prebundle:kb-model`。
apps/desktop/kb-model/

.env
.env.local
# Exception: gpt-image-2 ships a secret-free `.env` carrying ONLY the
# ENABLE_GARDEN_IMAGEGEN switch (the API key stays in env.json/host env). It
# must be tracked so it rides along into the packaged app — otherwise Mode A
# never turns on for end users. Safe because it holds no credentials.
!skills/gpt-image-2/.env
# Exception: same pattern for ppt-master — a secret-free `.env` carrying ONLY
# IMAGE_BACKEND/OPENAI_MODEL switches so AI image gen works out of the box on a
# fresh install. Credentials come from env.json/host env. Must be tracked to
# ride into the package.
!skills/ppt-master/.env
.vite
env.json
.gstack/
*.tsbuildinfo
.claude/settings.local.json

# open-design 运行时产物 (daemon/web 生成, 不入库)
.od
.od-e2e
.next
.next-*/
.tmp/
apps/web/out
e2e/.od-data

# 设计原型稿 (一次性方向稿, 不入库)
prototypes/
.design-proto/

# 一次性分析脚本 (与本项目无关：读别的项目数据生成 Excel，输出路径写死本机桌面)
scripts/export_his_analysis.py
