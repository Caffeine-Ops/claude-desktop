node_modules
out
dist
build/
*.log
.DS_Store

# fusion-code CLI 二进制 (~35M)：由 CI 在构建时下载（版本钉在
# .github/workflows/build.yml 的 FUSION_CODE_VERSION），不是源码，不入库。
apps/desktop/fusion-bin/

# prebundle 打包产物 (~160M)：scripts/prebundle-daemon.mjs 生成（每次先 rm 重建），
# 内容全是从 repo 别处复制来的（daemon bundle + apps/web/out + skills/
# design-systems/… 等根目录资源），无唯一副本。electron-builder 打包时用，
# 重新生成用 `bun run prebundle:daemon`。不入库。
apps/desktop/prebundled/

.env
.env.local
# Exception: gpt-image-2 ships a secret-free `.env` carrying ONLY the
# ENABLE_GARDEN_IMAGEGEN switch (the API key stays in env.json/host env). It
# must be tracked so it rides along into the packaged app — otherwise Mode A
# never turns on for end users. Safe because it holds no credentials.
!skills/gpt-image-2/.env
.vite
env.json
.gstack/
*.tsbuildinfo
.claude/settings.local.json

# open-design 运行时产物 (daemon/web 生成, 不入库)
.od
.od-e2e
.next
.next-*/
.tmp/
apps/web/out
e2e/.od-data

# 设计原型稿 (一次性方向稿, 不入库)
prototypes/
.design-proto/

# 一次性分析脚本 (与本项目无关：读别的项目数据生成 Excel，输出路径写死本机桌面)
scripts/export_his_analysis.py
