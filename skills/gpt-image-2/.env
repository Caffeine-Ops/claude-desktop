# Skill-bundled defaults loaded by scripts/shared.js loadAmbientEnv().
# Only the Mode A switch lives here — NO secrets. The OPENAI_API_KEY /
# OPENAI_BASE_URL come from the host environment (env.json → process.env),
# which takes precedence over this file. This keeps the key out of the
# skill directory while letting Mode A turn on automatically.
ENABLE_GARDEN_IMAGEGEN=1
