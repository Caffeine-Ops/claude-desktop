# ppt-master bundled switches — NO SECRETS.
#
# Ships with the claude-desktop app so AI image generation (image_gen.py) works
# out of the box. Holds ONLY non-secret switches: which backend + which model.
# The credentials (OPENAI_API_KEY / OPENAI_BASE_URL) are injected into the
# process environment by the host (env.json → engine, passed through to the
# skill subprocess) and ALWAYS win over this file.
#
# Lowest priority in the .env lookup order (see config.py get_env_candidates):
# a user-level ~/.ppt-master/.env or a cwd/repo .env is read first if present,
# so this file only kicks in on a fresh install with no other .env.
#
# Safe to commit (no credentials) — tracked via a .gitignore exception so it
# rides into the packaged app.

IMAGE_BACKEND=openai
OPENAI_MODEL=gpt-image-2
