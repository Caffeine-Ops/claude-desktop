{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "electron/main/**/*",
    "electron/preload/**/*",
    "electron/shared/**/*"
  ],
  // *.test.ts 由 `bun test` 运行（自带 bun:test 类型），不进 tsc——否则 tsc 无 bun
  // 类型会在 `import 'bun:test'` 处报错、拖垮唯一的质量门。
  "exclude": ["electron/**/*.test.ts"],
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": false
  }
}
