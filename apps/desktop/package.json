{
  "name": "@claude-desktop/desktop",
  "version": "0.0.16",
  "description": "Electron desktop wrapper around free-code CLI",
  "private": true,
  "author": "Caffeine-Ops",
  "repository": {
    "type": "git",
    "url": "https://github.com/Caffeine-Ops/claude-desktop.git"
  },
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:icons": "bash scripts/build-icons.sh",
    "prebundle:daemon": "bun scripts/prebundle-daemon.mjs",
    "prebundle:kb-model": "bun scripts/prebundle-kb-model.mjs",
    "verify:fusion": "bun scripts/verify-fusion-bin.mjs",
    "verify:kb-model": "bun scripts/verify-kb-model.mjs",
    "build:mac": "bun run verify:fusion && bun run build:icons && bun run prebundle:daemon && bun run prebundle:kb-model && bun run verify:kb-model && electron-vite build && electron-builder --mac --publish never",
    "build:win": "bun run verify:fusion win && bun run build:icons && bun run prebundle:daemon && bun run prebundle:kb-model && bun run verify:kb-model && electron-vite build && electron-builder --win --publish never",
    "build:linux": "bun run verify:fusion && bun run build:icons && bun run prebundle:daemon && bun run prebundle:kb-model && bun run verify:kb-model && electron-vite build && electron-builder --linux --publish never",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "test": "bun test src/",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.anthropic.claude-desktop",
    "productName": "Claude Desktop",
    "publish": [
      {
        "provider": "github",
        "owner": "Caffeine-Ops",
        "repo": "claude-desktop"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "env.json",
      "package.json"
    ],
    "asarUnpack": [
      "**/onnxruntime-node/**",
      "**/sharp/**",
      "**/@img/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "artifactName": "Claude-Desktop-${version}-${arch}-${os}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        },
        {
          "target": "zip",
          "arch": ["arm64"]
        }
      ],
      "identity": null,
      "files": [
        "!**/onnxruntime-node/bin/**/win32/**",
        "!**/onnxruntime-node/bin/**/linux/**"
      ],
      "extraResources": [
        {
          "from": "fusion-bin/fusion-code-cli",
          "to": "fusion-code-cli"
        },
        {
          "from": "prebundled",
          "to": "prebundled"
        },
        {
          "from": "node-runtime/mac",
          "to": "node-runtime"
        },
        {
          "from": "python-runtime/mac",
          "to": "python-runtime"
        },
        {
          "from": "kb-model",
          "to": "kb-model"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "files": [
        "!**/onnxruntime-node/bin/**/darwin/**",
        "!**/onnxruntime-node/bin/**/linux/**"
      ],
      "extraResources": [
        {
          "from": "fusion-bin/fusion-code-cli.exe",
          "to": "fusion-code-cli.exe"
        },
        {
          "from": "prebundled",
          "to": "prebundled"
        },
        {
          "from": "node-runtime/win",
          "to": "node-runtime"
        },
        {
          "from": "python-runtime/win",
          "to": "python-runtime"
        },
        {
          "from": "kb-model",
          "to": "kb-model"
        }
      ]
    },
    "linux": {
      "files": [
        "!**/onnxruntime-node/bin/**/darwin/**",
        "!**/onnxruntime-node/bin/**/win32/**"
      ],
      "extraResources": [
        {
          "from": "kb-model",
          "to": "kb-model"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.98",
    "@anthropic-ai/sdk": "^0.93.0",
    "@assistant-ui/core": "^0.1.13",
    "@assistant-ui/react": "^0.12.24",
    "@assistant-ui/react-markdown": "^0.12.8",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@huggingface/transformers": "4.2.0",
    "docx": "^9.7.1",
    "docx-preview": "^0.3.7",
    "electron-updater": "^6.3.9",
    "highlight.js": "^11.11.1",
    "image-size": "^2.0.2",
    "mermaid": "^11.16.0",
    "motion": "^12.38.0",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.7",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@open-design/ui": "workspace:*",
    "@tailwindcss/postcss": "4.3.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "4.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
