{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/**/*",
    "src/shared/**/*",
    "src/preload/*.d.ts"
  ],
  // *.test.ts 由 `bun test` 运行（自带 bun:test 类型），不进 tsc——否则 tsc 无 bun 类型
  // 会在 `import 'bun:test'` 处报错、拖垮唯一的质量门。
  "exclude": ["src/**/*.test.ts"],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@/*": ["src/renderer/src/*"]
    },
    "jsx": "react-jsx",
    "types": ["vite/client"]
  }
}
